# --- Security ---
WEBHOOK_SECRET=your_webhook_secret_here
LICENSE_ID=trial_user_001
LICENSE_URL=file://license_status.json
SHARING_ACTIVATION_KEY=MAKA-VALI-PRIME-2026

# --- Alpaca Credentials ---
# Paper (Active when ALPACA_PAPER=true)
ALPACA_PAPER_KEY=your_paper_key_here
ALPACA_PAPER_SECRET=your_paper_secret_here

# Live (Active when ALPACA_PAPER=false)
ALPACA_LIVE_KEY=your_live_key_here
ALPACA_LIVE_SECRET=your_live_secret_here

# Mode Selector (Set to false only when ready to go live)
ALPACA_PAPER=true

# --- Risk settings ---
STARTING_EQUITY=100000
USE_PERCENTAGE_RISK=true
RISK_PCT_PER_TRADE=0.25
MAX_DAILY_LOSS_PCT=2.5
MAX_TRADES_PER_DAY=100
MAX_OPEN_POSITIONS=5
MAX_ACCOUNT_DEPLOYMENT_PCT=25
MAX_POSITION_VALUE_DOLLARS=2500
STOP_LOSS_PCT=0.60
TAKE_PROFIT_PCT=3.0
TRAILING_STOP_PCT=0.40
TRAILING_STOP_ACTIVATION_PCT=0.35
SCALP_PROFIT_FLOOR=0.25
PARTIAL_TP1_DOLLARS=10.00
PARTIAL_TP2_DOLLARS=15.00
SHORT_EXIT_PROFIT_DOLLARS=5.00
ACTIVE_STRATEGIES=TREND,RSI,BREAKOUT,MA_CROSS,STOCHASTIC,PATTERNS,CHART,AUTO_TREND

# --- Trading hours (local machine time) ---
ALLOWED_START_HHMM=0400
ALLOWED_END_HHMM=2000
ENABLE_EXTENDED_HOURS=true

# --- Flask ---
HOST=0.0.0.0
PORT=5001
DEBUG=true

# --- Logs ---
LOG_DIR=logs
RISK_STATE_FILE=logs/risk_state.json
BOT_STATE_FILE=logs/bot_state.json
TRADE_JOURNAL_FILE=logs/trade_journal.jsonl
DAILY_SUMMARY_FILE=logs/daily_summary.jsonl

# --- Trading limits and constraints ---
ENABLE_NEW_ENTRIES=true
MAX_SPREAD_PCT=0.50
ORDER_TIMEOUT_SECONDS=180
MAX_CONSECUTIVE_FAILURES=5
TV_SCREENER_PRICE_MIN=1.00
TV_SCREENER_PRICE_MAX=100.00
TV_SCREENER_VOLUME_MIN=50000
TV_SCREENER_LIMIT=100
LIVE_TRADING_ACKNOWLEDGED=false
LIVE_MODE_WHITELIST_ONLY=false
LIVE_WHITELIST=SOFI,PLTR,F,BTC/USD,ETH/USD,TLT,BND
AUTO_SHUTDOWN_AFTER_CLOSE=false

AI_PROVIDER=OPENAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
ENABLE_AI_EVOLUTION=true
ENABLE_AI_TRADE_FILTER=false
ENABLE_NEWS_FILTER=false
KELLY_FRACTION=0.5
ATR_MULTIPLIER=2.0
VOL_SCALING_ENABLED=true
VOL_SCALING_FACTOR=1.0

# --- Crypto Long-Term Investment ---
CRYPTO_INVEST_EQUITY_PCT=1.0
CRYPTO_WHITELIST=BTC/USD,ETH/USD,SOL/USD

# --- Distributed Auto-Updates ---
ENABLE_AUTO_UPDATE=true
AUTO_UPDATE_BRANCH=main
AUTO_UPDATE_REMOTE=origin

# --- Notifications ---
DISCORD_WEBHOOK_URL=
PUSHOVER_USER_KEY=your_pushover_user_key_here
PUSHOVER_APP_TOKEN=your_pushover_app_token_here
INTRA_DAY_MODE_ONLY=true
MARKET_CLOSE_LIQUIDATION_WINDOW_MINS=15
ENABLE_INTERNET_RESEARCH=true

# --- 71-80 WEEKLY CASHFLOW & BANK WITHDRAWAL ---
BANK_WITHDRAWAL_ENABLED=false
BANK_ACCOUNT_ID=
MIN_CAPITAL_RESERVE=100000.0
WITHDRAWAL_DAY_OF_WEEK=4
WITHDRAWAL_TIME_HHMM=1630
AUTO_WITHDRAW_PROFITS=false

# --- LIVE TRADING SAFETY (Triple-Lock) ---
# Set to 'false' for Paper, 'https://api.alpaca.markets' for Live
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
# Set to 'true' only when you have pasted LIVE keys below
LIVE_MODE_ENABLED=false
# Required string for Live: I_UNDERSTAND_THIS_IS_REAL_MONEY
LIVE_TRADING_ACKNOWLEDGED=
