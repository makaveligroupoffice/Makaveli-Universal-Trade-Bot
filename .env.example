# --- Security ---
WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# --- Alpaca ---
ALPACA_KEY=YOUR_ALPACA_KEY_HERE
ALPACA_SECRET=YOUR_ALPACA_SECRET_HERE
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true

# --- Risk settings ---
STARTING_EQUITY=100000
USE_PERCENTAGE_RISK=true
RISK_PCT_PER_TRADE=2.0
MAX_DAILY_LOSS_PCT=5.0
MAX_TRADES_PER_DAY=25
MAX_OPEN_POSITIONS=5
MAX_ACCOUNT_DEPLOYMENT_PCT=85
MAX_POSITION_VALUE_DOLLARS=25000
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=5.0
TRAILING_STOP_PCT=1.0
# Strategy Family (Multi-Select): TREND, RSI, BOLLINGER, MACD, BREAKOUT, AGGRESSIVE
ACTIVE_STRATEGIES=TREND,RSI,BOLLINGER,MACD,BREAKOUT,AGGRESSIVE
SCALP_PROFIT_FLOOR=0.25

# --- Trading hours (local machine time) ---
ALLOWED_START_HHMM=0400
ALLOWED_END_HHMM=2000
ENABLE_EXTENDED_HOURS=true

# --- Flask ---
HOST=0.0.0.0
PORT=5000
DEBUG=true

# --- Logs ---
LOG_DIR=logs
RISK_STATE_FILE=logs/risk_state.json

BOT_STATE_FILE=logs/bot_state.json
TRADE_JOURNAL_FILE=logs/trade_journal.jsonl
DAILY_SUMMARY_FILE=logs/daily_summary.jsonl

ENABLE_NEW_ENTRIES=true
MAX_SPREAD_PCT=0.50
ORDER_TIMEOUT_SECONDS=180
MAX_CONSECUTIVE_FAILURES=5

MAX_POSITION_VALUE_DOLLARS=100.00
MAX_ACCOUNT_DEPLOYMENT_PCT=25.0

LIVE_TRADING_ACKNOWLEDGED=
LIVE_MODE_WHITELIST_ONLY=true
LIVE_WHITELIST=SOFI,PLTR,F
AUTO_SHUTDOWN_AFTER_CLOSE=true

# --- AI Configuration (Optional) ---
AI_PROVIDER=OPENAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4o
ENABLE_AI_EVOLUTION=true
ENABLE_AI_TRADE_FILTER=false

# --- Notifications ---
DISCORD_WEBHOOK_URL=YOUR_DISCORD_WEBHOOK_URL_HERE
PUSHOVER_USER_KEY=YOUR_PUSHOVER_USER_KEY_HERE
PUSHOVER_APP_TOKEN=YOUR_PUSHOVER_APP_TOKEN_HERE